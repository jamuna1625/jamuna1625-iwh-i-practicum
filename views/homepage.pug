doctype html
html
  head
    title= title
    link(rel='stylesheet', href='/css/styles.css')
  body
    h1 My Pets
    a(href='/update-cobj') Add a New Pet
    table
      thead
        tr
          th Name
          th Species
          th Bio
      tbody
        each pet in data
          tr
            td= pet.properties.name
            td= pet.properties.species
            td= pet.properties.bio
